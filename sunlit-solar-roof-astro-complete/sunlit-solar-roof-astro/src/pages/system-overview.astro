---
import Layout from '../layouts/Layout.astro';

const components = [
  { title: "Base and Waterproof Layer", desc: "The interface between the building structure and the solar roof package." },
  { title: "Active PV Elements", desc: "Solar-generating glass tiles or metal sheets depending on the selected system." },
  { title: "Inactive Roof Elements", desc: "Matching non-PV elements for roof areas that do not generate electricity." },
  { title: "Flashing and Drainage Details", desc: "Edge, transition and water-management details selected according to roof layout." },
  { title: "Fixings and Accessories", desc: "Fasteners, ridge pieces, edge pieces and other roof integration components." },
  { title: "Project Documents", desc: "Datasheets, installation notes and quotation documents based on project stage." }
];

const buyerBenefits = [
  { title: "Clearer Scope", desc: "The buyer can see what is included in the roof package instead of comparing isolated PV tiles only." },
  { title: "Better Roof Coverage", desc: "Active and inactive elements are discussed together, which is essential for a complete roof." },
  { title: "Easier Quotation", desc: "Roof drawing, active layout, inactive coverage and accessories can be discussed as one project scope." },
  { title: "Better Local Installation Discussion", desc: "Local roof and electrical teams can review a clearer system package and document set." }
];

const comparison = [
  ["Positioning", "Premium slate-look glass system", "Modern metal solar roof system"],
  ["Active Element", "AG-etched glass PV roof tile", "Metal solar roof sheet"],
  ["Inactive Element", "Matching glass inactive tile", "Matching inactive metal element"],
  ["Appearance", "Premium slate-like glass roof", "Contemporary metal roof profile"],
  ["Best Fit", "Villas and architectural projects", "Residential, commercial and large roof projects"],
  ["Cost Position", "Premium", "More cost-effective"]
];
---

<Layout title="Complete Solar Roof System Overview">
  <section class="bg-[#f8faf8] py-14 md:py-20">
    <div class="container mx-auto px-4 max-w-4xl">
      <p class="sunlit-overline mb-4">System Overview</p>
      <h1 class="sunlit-section-title text-4xl md:text-6xl mb-6">Complete Solar Roof Systems, Not Just Solar Tiles</h1>
      <p class="text-lg md:text-xl text-[var(--slate)] leading-relaxed">
        A real solar roof project needs more than active PV tiles. It needs a coordinated roof package with active elements, matching inactive coverage, flashing, fixings, accessories and project documentation.
      </p>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-3 gap-10 items-start">
        <div>
          <p class="sunlit-overline mb-3">Definition</p>
          <h2 class="sunlit-section-title text-3xl md:text-4xl mb-4">What Makes a Solar Roof Complete?</h2>
          <p class="text-[var(--slate)] leading-relaxed">
            A complete solar roof system is a coordinated roof package. It combines solar-generating elements, non-solar matching roof elements and roof integration components so the finished roof can protect the building and generate electricity.
          </p>
        </div>
        <div class="lg:col-span-2 grid sm:grid-cols-2 gap-5">
          {components.map((item, index) => (
            <div class="sunlit-card p-6">
              <div class="text-xs font-extrabold text-[var(--deep-green)] mb-3">0{index + 1}</div>
              <h3 class="font-extrabold text-[var(--charcoal)] mb-2">{item.title}</h3>
              <p class="text-sm text-[var(--slate)] leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-[#f8faf8]">
    <div class="container mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <p class="sunlit-overline mb-3">B2B Buying Logic</p>
        <h2 class="sunlit-section-title text-3xl md:text-5xl mb-4">Why Complete Systems Matter</h2>
        <p class="text-[var(--slate)]">For distributors, installers, contractors and developers, the main decision is not only wattage. The roof package, installation logic and accessory scope also matter.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">
        {buyerBenefits.map((item) => (
          <div class="sunlit-card p-6">
            <h3 class="font-extrabold text-[var(--charcoal)] mb-3">{item.title}</h3>
            <p class="text-sm text-[var(--slate)] leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mb-10">
        <p class="sunlit-overline mb-3">System Comparison</p>
        <h2 class="sunlit-section-title text-3xl md:text-5xl mb-4">Lumina Slate or Storm Guard?</h2>
        <p class="text-[var(--slate)]">The right choice depends on roof appearance, buyer role, project size and budget position.</p>
      </div>
      <div class="sunlit-card overflow-hidden">
        <div class="grid grid-cols-3 bg-[var(--deep-green)] text-white font-extrabold">
          <div class="p-4">Decision Point</div>
          <div class="p-4">Lumina Slate</div>
          <div class="p-4">Storm Guard</div>
        </div>
        {comparison.map((row) => (
          <div class="grid grid-cols-3 border-b border-[var(--border)] last:border-b-0">
            <div class="p-4 font-extrabold text-[var(--charcoal)]">{row[0]}</div>
            <div class="p-4 text-[var(--slate)]">{row[1]}</div>
            <div class="p-4 text-[var(--slate)]">{row[2]}</div>
          </div>
        ))}
      </div>
      <div class="flex flex-col sm:flex-row gap-4 mt-8">
        <a href="/lumina-slate/" class="sunlit-btn-secondary">View Lumina Slate</a>
        <a href="/storm-guard/" class="sunlit-btn-secondary">View Storm Guard</a>
        <a href="/contact/" class="sunlit-btn-primary">Send Roof Drawing</a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20 dark-green-gradient text-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-5xl font-extrabold mb-5">Start with Your Roof Drawing</h2>
      <p class="text-lg text-white/75 max-w-2xl mx-auto mb-8">Send project country, roof area and drawings. We will help discuss system choice, product scope and quotation direction.</p>
      <a href="/contact/" class="sunlit-btn-primary">Request Project Review</a>
    </div>
  </section>
</Layout>
