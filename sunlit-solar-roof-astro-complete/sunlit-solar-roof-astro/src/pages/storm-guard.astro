---
import Layout from '../layouts/Layout.astro';
import { getComponentsBySystem } from '../data/systemComponents';
import { productFAQs, generalFAQs } from '../data/faqs';

const components = getComponentsBySystem('Storm Guard');
const faqs = [...productFAQs, ...generalFAQs].slice(0, 5);
const heroImage = "https://d2xsxph8kpxj0f.cloudfront.net/310519663705242844/mtvS4X69r9pvLdqcQTXPeQ/storm-guard-hero-Rv3C82SNHYaBM2TVgU4t7W.webp";

const specs = [
  ["System Type", "Modern metal solar roof system"],
  ["Active Element", "Low-standing-seam Al-Mg-Mn metal solar roof sheets"],
  ["Inactive Element", "Matching inactive metal roof elements"],
  ["Main Buyer Value", "Lower cost position than premium glass systems"],
  ["Best Fit", "Modern residential, commercial, public and large roof projects"],
  ["Documents", "Datasheets and warranty documents available upon request"]
];

const applications = ["Modern homes", "Commercial buildings", "Public buildings", "Large roof projects"];
---

<Layout title="Storm Guard Metal Solar Roof System">
  <section class="border-b border-[var(--border)] bg-white">
    <div class="container mx-auto px-4 py-4 text-sm text-[var(--slate)]">
      <a href="/" class="hover:text-[var(--deep-green)]">Home</a>
      <span class="mx-2">/</span>
      <a href="/system-overview/" class="hover:text-[var(--deep-green)]">Solar Roof Systems</a>
      <span class="mx-2">/</span>
      <span class="font-bold text-[var(--charcoal)]">Storm Guard</span>
    </div>
  </section>

  <section class="bg-[#f8faf8] py-14 md:py-20">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="sunlit-overline mb-4">Cost-Effective Metal Solar Roof System</p>
          <h1 class="sunlit-section-title text-4xl md:text-6xl mb-6">Storm Guard Metal Solar Roof System</h1>
          <p class="text-lg md:text-xl text-[var(--slate)] leading-relaxed mb-8">
            A low-standing-seam Al-Mg-Mn metal solar roofing system with active solar sheets, matching inactive metal roof elements, flashing, fixings and accessories. It is designed for modern residential, commercial, public and large roof projects.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 mb-8">
            <a href="/contact/" class="sunlit-btn-primary">Request Storm Guard Quote</a>
            <a href="/resources/" class="sunlit-btn-secondary">Request Datasheet</a>
          </div>
          <div class="grid grid-cols-3 gap-3">
            <div class="stat-pill p-4"><div class="font-extrabold text-[var(--deep-green)]">Metal</div><div class="text-xs text-[var(--slate)]">Modern roof profile</div></div>
            <div class="stat-pill p-4"><div class="font-extrabold text-[var(--deep-green)]">Practical</div><div class="text-xs text-[var(--slate)]">Broad application</div></div>
            <div class="stat-pill p-4"><div class="font-extrabold text-[var(--deep-green)]">Project Based</div><div class="text-xs text-[var(--slate)]">Quoted by roof layout</div></div>
          </div>
        </div>
        <div class="sunlit-card overflow-hidden p-3">
          <img src={heroImage} alt="Storm Guard metal solar roof system" class="w-full h-[420px] object-cover rounded-2xl" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-3 gap-10 items-start">
        <div>
          <p class="sunlit-overline mb-3">What This System Is</p>
          <h2 class="sunlit-section-title text-3xl md:text-4xl mb-4">Modern Metal Roofing with Integrated Solar</h2>
          <p class="text-[var(--slate)] leading-relaxed">
            Storm Guard combines active metal solar roof sheets and matching inactive metal roof elements into a coordinated roof package. It is intended for buyers who need a clean metal roof appearance, practical project coverage and a more cost-effective alternative to premium glass solar roofing.
          </p>
        </div>
        <div class="lg:col-span-2 grid sm:grid-cols-2 gap-5">
          <div class="sunlit-card p-6">
            <div class="h-32 image-placeholder rounded-2xl mb-5"></div>
            <h3 class="font-extrabold text-xl mb-2">Active Metal Solar Sheet</h3>
            <p class="text-[var(--slate)] leading-relaxed">The active roof sheet combines metal roofing appearance with photovoltaic power generation.</p>
          </div>
          <div class="sunlit-card p-6">
            <div class="h-32 image-placeholder rounded-2xl mb-5"></div>
            <h3 class="font-extrabold text-xl mb-2">Matching Inactive Element</h3>
            <p class="text-[var(--slate)] leading-relaxed">Inactive metal roof elements cover areas where solar generation is not required while keeping a consistent roof appearance.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-[#f8faf8]">
    <div class="container mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <p class="sunlit-overline mb-3">System Package</p>
        <h2 class="sunlit-section-title text-3xl md:text-5xl mb-4">What the Storm Guard Package Includes</h2>
        <p class="text-[var(--slate)]">The exact bill of materials depends on the project roof layout. The package may include the following coordinated components.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-5 gap-5">
        {components.map((component, index) => (
          <div class="sunlit-card p-5">
            <div class="text-xs font-extrabold text-[var(--deep-green)] mb-3">0{index + 1}</div>
            <h3 class="font-extrabold text-[var(--charcoal)] mb-2">{component.name}</h3>
            <p class="text-sm text-[var(--slate)] leading-relaxed">{component.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-10">
        <div>
          <p class="sunlit-overline mb-3">Technical Snapshot</p>
          <h2 class="sunlit-section-title text-3xl md:text-4xl mb-4">Key Information for Early Evaluation</h2>
          <p class="text-[var(--slate)] mb-6">Final specifications depend on project configuration, roof layout and selected components. Detailed datasheets are available upon request.</p>
          <a href="/contact/" class="sunlit-btn-green">Send Roof Drawing</a>
        </div>
        <div class="sunlit-card overflow-hidden">
          {specs.map(([label, value]) => (
            <div class="grid grid-cols-3 gap-4 p-4 border-b border-[var(--border)] last:border-b-0">
              <div class="font-extrabold text-[var(--charcoal)]">{label}</div>
              <div class="col-span-2 text-[var(--slate)]">{value}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-[#f8faf8]">
    <div class="container mx-auto px-4">
      <p class="sunlit-overline text-center mb-3">Suitable Projects</p>
      <div class="grid md:grid-cols-4 gap-4">
        {applications.map((app) => (
          <div class="sunlit-card-soft p-6 text-center font-extrabold text-[var(--charcoal)]">{app}</div>
        ))}
      </div>
    </div>
  </section>

  <section id="faq" class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <h2 class="sunlit-section-title text-3xl md:text-5xl mb-10 text-center">Storm Guard FAQ</h2>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <div class="border border-[var(--border)] rounded-2xl p-6">
            <h3 class="font-extrabold text-[var(--charcoal)] mb-2">{faq.question}</h3>
            <p class="text-[var(--slate)] leading-relaxed">{faq.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20 dark-green-gradient text-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-5xl font-extrabold mb-5">Evaluate Storm Guard for Your Project</h2>
      <p class="text-lg text-white/75 max-w-2xl mx-auto mb-8">Send your roof drawing, country and estimated roof area. We will help discuss active and inactive coverage, product scope and quotation direction.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact/" class="sunlit-btn-primary">Request Storm Guard Quote</a>
        <a href="/projects/" class="border border-white/60 text-white rounded-full px-6 py-3 font-extrabold hover:bg-white/10">View Projects</a>
      </div>
    </div>
  </section>
</Layout>
