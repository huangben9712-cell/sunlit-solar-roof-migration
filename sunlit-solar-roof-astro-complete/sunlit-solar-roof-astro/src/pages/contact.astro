---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Sunlit Solar Roof">
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <h1 class="text-4xl font-bold mb-6">Request a Solar Roof Project Quote</h1>
      <p class="text-lg text-gray-600 mb-8">
        Send your project country, roof area, preferred system and roof drawing if available. We will help discuss system choice, product scope and quotation direction.
      </p>
      <div class="grid md:grid-cols-2 gap-8">
        <div>
          <h2 class="text-2xl font-bold mb-4">Contact</h2>
          <p class="mb-2"><a href="mailto:info@sunlitsolarroof.com" class="text-green-700 font-semibold">info@sunlitsolarroof.com</a></p>
          <p class="text-gray-600">Changzhou, Jiangsu, China</p>
        </div>
        <form class="space-y-4" method="POST" action="/thank-you/">
          <input name="name" required placeholder="Full Name" class="w-full border rounded-lg px-4 py-3" />
          <input name="email" type="email" required placeholder="Email" class="w-full border rounded-lg px-4 py-3" />
          <input name="company" required placeholder="Company" class="w-full border rounded-lg px-4 py-3" />
          <input name="country" required placeholder="Country / Region" class="w-full border rounded-lg px-4 py-3" />
          <select name="buyerType" required class="w-full border rounded-lg px-4 py-3">
            <option value="">Buyer Type</option>
            <option value="distributor">Distributor / Importer</option>
            <option value="installer">Solar Installer</option>
            <option value="contractor">Roofing Contractor</option>
            <option value="developer">Developer</option>
            <option value="other">Other</option>
          </select>
          <textarea name="message" required placeholder="Message / Project Description" class="w-full border rounded-lg px-4 py-3 h-32"></textarea>
          <button type="submit" class="w-full bg-green-700 text-white font-semibold py-3 rounded-lg">Submit Inquiry</button>
        </form>
      </div>
    </div>
  </section>
</Layout>
