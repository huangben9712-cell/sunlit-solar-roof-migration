---
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/projects';
---

<Layout title="Project References - Sunlit Solar Roof">
  <section class="bg-[#f8faf8] py-14 md:py-20">
    <div class="container mx-auto px-4 max-w-4xl">
      <p class="sunlit-overline mb-4">Project References</p>
      <h1 class="sunlit-section-title text-4xl md:text-6xl mb-6">Solar Roof Project References</h1>
      <p class="text-lg text-[var(--slate)] leading-relaxed">
        Reference projects showing how Lumina Slate and Storm Guard systems can be used across residential, commercial, hospitality, community and infrastructure applications. Detailed project data is shared during quotation discussion when available.
      </p>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {projects.map((project) => (
          <a href={`/projects/${project.slug}/`} class="sunlit-card overflow-hidden block hover:-translate-y-1 transition">
            <div class="h-52 image-placeholder"></div>
            <div class="p-6">
              <div class="flex gap-2 flex-wrap mb-4">
                <span class="inline-block bg-blue-50 text-blue-700 text-xs font-extrabold px-3 py-1 rounded-full">{project.system}</span>
                <span class="inline-block bg-green-50 text-green-700 text-xs font-extrabold px-3 py-1 rounded-full">{project.application}</span>
              </div>
              <h3 class="text-xl font-extrabold text-[var(--charcoal)] mb-3 line-clamp-2">{project.name}</h3>
              <p class="text-sm text-[var(--slate)] mb-5">{project.location}</p>
              <div class="text-[var(--deep-green)] font-extrabold text-sm">View Project</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20 dark-green-gradient text-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-5xl font-extrabold mb-5">Have a Similar Project?</h2>
      <p class="text-lg text-white/75 max-w-2xl mx-auto mb-8">
        Send your roof drawing and project details. We will help you evaluate the right system and quotation direction.
      </p>
      <a href="/contact/" class="sunlit-btn-primary">Send Roof Drawing</a>
    </div>
  </section>
</Layout>
