---
import Layout from '../../layouts/Layout.astro';
import { projects } from '../../data/projects.ts';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props {
  project: typeof projects[0];
}

const { project } = Astro.props;
const clean = (value?: string) => value && value !== 'Available upon request' ? value : undefined;
const relatedProjects = projects.filter((p) => p.system === project.system && p.id !== project.id).slice(0, 3);
---

<Layout title={project.name}>
  <section class="border-b border-[var(--border)] bg-white">
    <div class="container mx-auto px-4 py-4 text-sm text-[var(--slate)]">
      <a href="/" class="hover:text-[var(--deep-green)]">Home</a>
      <span class="mx-2">/</span>
      <a href="/projects/" class="hover:text-[var(--deep-green)]">Projects</a>
      <span class="mx-2">/</span>
      <span class="font-bold text-[var(--charcoal)]">{project.name}</span>
    </div>
  </section>

  <section class="bg-[#f8faf8] py-14 md:py-20">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl">
        <p class="sunlit-overline mb-4">Project Reference</p>
        <h1 class="sunlit-section-title text-4xl md:text-6xl mb-6">{project.name}</h1>
        <div class="flex gap-2 flex-wrap">
          <span class="inline-block bg-blue-50 text-blue-700 text-sm font-extrabold px-4 py-2 rounded-full">{project.system}</span>
          <span class="inline-block bg-green-50 text-green-700 text-sm font-extrabold px-4 py-2 rounded-full">{project.application}</span>
          <span class="inline-block bg-white text-[var(--slate)] text-sm font-extrabold px-4 py-2 rounded-full border border-[var(--border)]">{project.location}</span>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-3 gap-10">
        <div class="lg:col-span-2">
          <div class="h-80 image-placeholder rounded-3xl mb-8"></div>
          <div class="sunlit-card p-8 mb-8">
            <h2 class="text-2xl font-extrabold text-[var(--charcoal)] mb-4">Project Overview</h2>
            {clean(project.overview) ? (
              <p class="text-[var(--slate)] leading-relaxed">{project.overview}</p>
            ) : (
              <p class="text-[var(--slate)] leading-relaxed">
                This project reference shows the application of a Sunlit integrated solar roof system. Detailed project information, roof drawings, system configuration and technical data are available during project discussion when they are relevant to a similar inquiry.
              </p>
            )}
          </div>

          {clean(project.challenge) && (
            <div class="sunlit-card p-8 mb-8">
              <h2 class="text-2xl font-extrabold text-[var(--charcoal)] mb-4">Project Challenge</h2>
              <p class="text-[var(--slate)] leading-relaxed">{project.challenge}</p>
            </div>
          )}

          {clean(project.sunlitSolution) && (
            <div class="sunlit-card p-8 mb-8">
              <h2 class="text-2xl font-extrabold text-[var(--charcoal)] mb-4">Sunlit Solution</h2>
              <p class="text-[var(--slate)] leading-relaxed">{project.sunlitSolution}</p>
            </div>
          )}
        </div>

        <aside>
          <div class="sunlit-card p-6 sticky top-24">
            <h3 class="font-extrabold text-[var(--charcoal)] mb-5">Project Details</h3>
            <div class="space-y-4">
              <div class="pb-4 border-b border-[var(--border)]">
                <p class="text-sm text-[var(--slate)] mb-1">Location</p>
                <p class="font-extrabold text-[var(--charcoal)]">{project.location}</p>
              </div>
              <div class="pb-4 border-b border-[var(--border)]">
                <p class="text-sm text-[var(--slate)] mb-1">System</p>
                <p class="font-extrabold text-[var(--charcoal)]">{project.system}</p>
              </div>
              <div class="pb-4 border-b border-[var(--border)]">
                <p class="text-sm text-[var(--slate)] mb-1">Application</p>
                <p class="font-extrabold text-[var(--charcoal)]">{project.application}</p>
              </div>
              {clean(project.roofArea) && (
                <div class="pb-4 border-b border-[var(--border)]">
                  <p class="text-sm text-[var(--slate)] mb-1">Roof Area</p>
                  <p class="font-extrabold text-[var(--charcoal)]">{project.roofArea}</p>
                </div>
              )}
              {clean(project.capacity) && (
                <div class="pb-4 border-b border-[var(--border)]">
                  <p class="text-sm text-[var(--slate)] mb-1">Capacity</p>
                  <p class="font-extrabold text-[var(--charcoal)]">{project.capacity}</p>
                </div>
              )}
            </div>
            <a href="/contact/" class="sunlit-btn-primary w-full mt-6">Discuss Similar Project</a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  {relatedProjects.length > 0 && (
    <section class="py-16 md:py-24 bg-[#f8faf8]">
      <div class="container mx-auto px-4">
        <h2 class="sunlit-section-title text-3xl md:text-5xl mb-10 text-center">Related Projects</h2>
        <div class="grid md:grid-cols-3 gap-6">
          {relatedProjects.map((relatedProject) => (
            <a href={`/projects/${relatedProject.slug}/`} class="sunlit-card overflow-hidden block">
              <div class="h-40 image-placeholder"></div>
              <div class="p-5">
                <h3 class="font-extrabold text-[var(--charcoal)] mb-2 line-clamp-2">{relatedProject.name}</h3>
                <p class="text-sm text-[var(--slate)]">{relatedProject.location}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>
