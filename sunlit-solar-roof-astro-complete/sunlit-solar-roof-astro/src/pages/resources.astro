---
import Layout from '../layouts/Layout.astro';
import { getPublicGuides, getRequestDocuments } from '../data/resources';

const publicGuides = getPublicGuides();
const requestDocs = getRequestDocuments();
---

<Layout title="Resources for Solar Roof Buyers">
  <section class="bg-[#f8faf8] py-14 md:py-20">
    <div class="container mx-auto px-4 max-w-4xl">
      <p class="sunlit-overline mb-4">Buyer Resources</p>
      <h1 class="sunlit-section-title text-4xl md:text-6xl mb-6">Solar Roof Guides and Technical Documents</h1>
      <p class="text-lg md:text-xl text-[var(--slate)] leading-relaxed">
        Practical resources for overseas buyers evaluating complete solar roof systems, comparing Lumina Slate and Storm Guard, and preparing project information for quotation.
      </p>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mb-10">
        <p class="sunlit-overline mb-3">Public Guides</p>
        <h2 class="sunlit-section-title text-3xl md:text-5xl mb-4">Learn Before You Request a Quote</h2>
        <p class="text-[var(--slate)]">These guides explain the buying logic behind complete solar roof systems and help you prepare better project information.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {publicGuides.map((guide) => (
          <a href={`/resources/${guide.slug}/`} class="sunlit-card p-7 block hover:-translate-y-1 transition">
            <p class="text-sm font-extrabold text-[var(--deep-green)] mb-3">Buyer Guide</p>
            <h3 class="text-xl font-extrabold text-[var(--charcoal)] mb-3">{guide.title}</h3>
            <p class="text-[var(--slate)] leading-relaxed mb-5">{guide.summary}</p>
            <span class="text-[var(--deep-green)] font-extrabold">Read Guide</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-[#f8faf8]">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mb-10">
        <p class="sunlit-overline mb-3">Request Documents</p>
        <h2 class="sunlit-section-title text-3xl md:text-5xl mb-4">Technical Documents for Active Projects</h2>
        <p class="text-[var(--slate)]">Catalogs, datasheets, installation notes, warranty documents and project files are shared based on the system and project stage.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {requestDocs.map((doc) => (
          <div class="sunlit-card p-6">
            <p class="text-sm font-extrabold text-[var(--deep-green)] mb-3">Request Document</p>
            <h3 class="font-extrabold text-[var(--charcoal)] mb-2">{doc.title}</h3>
            <p class="text-sm text-[var(--slate)] mb-5 leading-relaxed">{doc.summary}</p>
            <a href="/contact/" class="text-[var(--deep-green)] font-extrabold text-sm">Request Document</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20 dark-green-gradient text-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-5xl font-extrabold mb-5">Need Documents for a Real Project?</h2>
      <p class="text-lg text-white/75 max-w-2xl mx-auto mb-8">
        Send your project country, roof area and preferred system. We will point you to the right documents and next steps.
      </p>
      <a href="/contact/" class="sunlit-btn-primary">Request Documents</a>
    </div>
  </section>
</Layout>
